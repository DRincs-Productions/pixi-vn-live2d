{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["node"],
    "paths": {
      "@drincs/pixi-vn-live2d/core": ["../src/core/index.ts"],
      "@drincs/pixi-vn-live2d": ["../src/index.ts"],
      "@/*": ["../src/*"]
    }
  },
  "include": ["src"]
}
