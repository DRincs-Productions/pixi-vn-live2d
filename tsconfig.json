{
  "compilerOptions": {
    "target": "ESNext",
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@drincs/pixi-vn-live2d/core": ["./src/core/index.ts"],
      "pixi.js": ["./node_modules/@drincs/pixi-vn/pixi.js"],
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
